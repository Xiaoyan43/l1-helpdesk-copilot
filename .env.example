# 复制为 .env 后按需填写。⚠️ 仅用于个人作品 / lab 租户，切勿填生产凭据。

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
USE_MOCK_LLM=true            # true=用本地规则基线，不调用 API；拿到 key 后改 false

# --- Microsoft Graph (免费 M365 开发者租户) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_DRY_RUN=true          # true=只演练打印将执行的动作，不真的修改租户
